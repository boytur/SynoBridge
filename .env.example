# --- Auth0 Configuration ---
# Your Auth0 Domain (e.g., your-tenant.us.auth0.com)
AUTH0_DOMAIN=
# Your Auth0 Application Client ID
AUTH0_CLIENT_ID=
# Your Auth0 API Identifier (Audience)
AUTH0_AUDIENCE=

# --- Security ---
# Comma-separated list of allowed user emails. Leave empty to allow all authenticated users.
ALLOWED_EMAILS=
# 32-character string used to encrypt SMB credentials in the database
ENCRYPTION_KEY=changeme32byteskey1234567890123

# --- Networking ---
# The URL of the frontend (used for CORS and redirect URI)
FRONTEND_URL=http://localhost:5173
# The URL of the backend API
VITE_API_URL=http://localhost:8080

# --- Frontend (Vite requires VITE_ prefix) ---
# These MUST match the values above for the frontend to work
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
